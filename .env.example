# Flask Secret Key (Optional - a default will be used if not set)
SECRET_KEY=your_flask_secret_key_here

# Google Gemini API Key - Get your key from https://aistudio.google.com/ (Required for AI assistant)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key - Get your key from https://console.groq.com/ (Optional)
GROQ_API_KEY=your_groq_api_key_here

# Database Configuration (Optional - defaults to SQLite if not set)
# To use SQLite, leave the database configs blank.
# To use MySQL, uncomment and configure the variables below:
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USERNAME=root
# MYSQL_PASSWORD=your_mysql_password_here
# MYSQL_DATABASE=inventory_db
